# Copy to .env.production (gitignored) for release/store builds.
AUTH_DOMAIN=
AUTH_CLIENT_ID=
AUTH_AUDIENCE=
LAUNCHDARKLY_CLIENT_SIDE_ID=
LAUNCHDARKLY_MOBILE_KEY=
# Required on iPhone: HTTPS URL where users upgrade (web checkout; App Store policy).
SUBSCRIPTION_BILLING_WEB_URL=https://your-domain.example/subscriptions
# Google Maps API key (enable Maps SDK for Android/iOS in Google Cloud Console).
# Release builds: run ./scripts/sync_ios_secrets.sh production before archiving.
GOOGLE_MAPS_API_KEY=
