# frozen_string_literal: true

default_platform(:ios)

def asc_api_key
  key_id = ENV.fetch("ASC_API_KEY_ID")
  issuer_id = ENV.fetch("ASC_API_ISSUER_ID")
  key_path = File.expand_path(
    "../../private_keys/AuthKey_#{key_id}.p8",
    __dir__
  )

  unless File.exist?(key_path)
    UI.user_error!("missing App Store Connect private key: #{key_path}")
  end

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_filepath: key_path,
    duration: 1200,
    in_house: false
  )
end

platform :ios do
  desc "Upload IPA to TestFlight"
  lane :upload_ipa do |options|
    ipa = options[:ipa]
    UI.user_error!("ipa path is required (pass ipa:/path/to/app.ipa)") if ipa.to_s.empty?
    UI.user_error!("IPA not found: #{ipa}") unless File.exist?(ipa)

    upload_to_testflight(
      api_key: asc_api_key,
      ipa: ipa,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload App Store listing metadata and screenshots (no binary)"
  lane :upload_metadata do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Download App Store listing metadata from App Store Connect"
  lane :download_metadata do |options|
    require "deliver"
    require "deliver/setup"
    require "deliver/download_screenshots"

    with_screenshots = options[:screenshots].to_s == "true"

    deliver_options = FastlaneCore::Configuration.create(
      Deliver::Options.available_options,
      api_key: asc_api_key,
      app_identifier: CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier),
      platform: "ios",
      force: true,
      skip_binary_upload: true
    )

    Deliver::Runner.new(deliver_options)

    metadata_path = File.join(__dir__, "metadata")
    unless Deliver::CommandsGenerator.force_overwrite_metadata?(deliver_options, metadata_path)
      UI.important("Metadata download cancelled.")
      next
    end

    app = Deliver.cache[:app]
    platform = Spaceship::ConnectAPI::Platform.map(deliver_options[:platform])
    version = app.get_latest_app_store_version(platform: platform)
    Deliver::Setup.new.generate_metadata_files(app, version, metadata_path, deliver_options)

    if with_screenshots
      screenshots_path = File.join(__dir__, "screenshots")
      Deliver::DownloadScreenshots.run(deliver_options, screenshots_path)
    end
  end
end
