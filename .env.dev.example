# Copy to .env.dev (gitignored) for local development.
AUTH_DOMAIN=
AUTH_CLIENT_ID=
AUTH_AUDIENCE=
LAUNCHDARKLY_CLIENT_SIDE_ID=
LAUNCHDARKLY_MOBILE_KEY=
# Optional: only needed for iOS App Store builds (Safari billing).
SUBSCRIPTION_BILLING_WEB_URL=
# Google Maps API key for coach search map view.
# Enable "Maps SDK for Android" and "Maps SDK for iOS" in Google Cloud Console.
# Local dev (flutter run): the app reads this key at startup via MethodChannel.
# Release / Xcode archives: also run ./scripts/sync_ios_secrets.sh <env> before building.
GOOGLE_MAPS_API_KEY=
